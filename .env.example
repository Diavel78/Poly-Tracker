# Polymarket US API Credentials
# Generate at https://polymarket.us/developer after iOS app identity verification
POLYMARKET_KEY_ID=your-key-id-uuid-here
POLYMARKET_SECRET_KEY=your-base64-ed25519-private-key-here

# Dashboard Login Credentials (pick your own username/password)
DASHBOARD_USER=admin
DASHBOARD_PASS=change-me-to-a-strong-password

# Owls Insight API Key (multi-sportsbook odds)
OWLS_INSIGHT_API_KEY=owlsinsight_your-key-here

# Flask Settings
FLASK_SECRET_KEY=change-me-to-a-random-string
PORT=5000
